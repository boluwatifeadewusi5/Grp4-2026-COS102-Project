# Beta 1.2 uses Postgres only.
#
# Online mode:
# 1. Create a Supabase or Neon Postgres database.
# 2. Copy the pooled/session connection string.
# 3. Set CIVIC_CONNECT_DATABASE_URL before running or packaging the app.
#
# Offline mode:
# 1. Install and start Postgres on this computer.
# 2. Create a local database named civic_connect.
# 3. Leave CIVIC_CONNECT_DATABASE_URL empty, or set CIVIC_CONNECT_LOCAL_DATABASE_URL.
#
# Online example:
# CIVIC_CONNECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
CIVIC_CONNECT_DATABASE_URL=

# Optional local override. If unset, the app uses:
# postgresql://postgres:postgres@localhost:5432/civic_connect
CIVIC_CONNECT_LOCAL_DATABASE_URL=

# Refresh logged-in screens every 1 to 5 seconds. Default: 5.
CIVIC_CONNECT_REFRESH_SECONDS=5

# Stop very slow queries from freezing the desktop UI. Set to 0 to disable.
CIVIC_CONNECT_QUERY_TIMEOUT_MS=5000

# Optional development-only starter data. Leave disabled for real users.
CIVIC_CONNECT_SEED_STARTER_DATA=0
CIVIC_CONNECT_SEED_PASSWORD=
