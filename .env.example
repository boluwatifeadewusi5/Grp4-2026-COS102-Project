# Local default: leave this unset and Civic Connect uses SQLite at ~/.civic_connect_tkinter/civic_connect.sqlite3
#
# Hosted database mode:
# 1. Create a Supabase or Neon Postgres database.
# 2. Copy the pooled/session connection string.
# 3. Set this variable before running or packaging the app.
#
# Example:
# CIVIC_CONNECT_DATABASE_URL=postgresql://postgres.example:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
CIVIC_CONNECT_DATABASE_URL=

# Optional: keep demo seed data on first run. The app seeds only when the users table is empty.
